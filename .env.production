# Production (Vercel) — FE points at the live BE at apitest.ftes.vn.
# NEXT_PUBLIC_* are build-time PUBLIC values (shipped to the browser) — no secrets here.
NEXT_PUBLIC_API_HTTP_BASE_URL=https://apitest.ftes.vn/api/v1
NEXT_PUBLIC_API_GRAPHQL_BASE_URL=https://apitest.ftes.vn/api/v1/graphql
NEXT_PUBLIC_API_WEBSOCKET_BASE_URL=wss://apitest.ftes.vn
NEXT_PUBLIC_DEBUG=false
